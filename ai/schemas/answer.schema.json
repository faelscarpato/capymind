{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapyMind Agent Answer",
  "type": "object",
  "required": [
    "answer",
    "sources"
  ],
  "properties": {
    "answer": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "section": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}