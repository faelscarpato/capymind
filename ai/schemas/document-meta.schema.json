{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Document Frontmatter Metadata",
  "type": "object",
  "required": [
    "id",
    "title",
    "doc_type",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "doc_type": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "version": {
      "type": "string"
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ]
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    }
  }
}